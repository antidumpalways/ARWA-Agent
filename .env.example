# =============================================================================
# ParkFlow Agent — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env` to git.
# =============================================================================

# ---------- Network ----------
CASPER_NETWORK=casper-test
CASPER_RPC_URL=https://node.testnet.cspr.cloud
CASPER_CHAIN_NAME=casper-test

# ---------- Agent key (NEVER commit) ----------
# Path to a PEM-encoded Ed25519 or Secp256k1 key, funded with Testnet CSPR.
# Generate with: casper-client keygen keys/agent.pem
# Faucet: https://testnet.cspr.live/tools/faucet
AGENT_SECRET_KEY_PATH=./keys/agent.pem
# Auto-derived from PEM on first run, exposed for x402 client:
# AGENT_PUBLIC_KEY=01abc...

# ---------- Deployed contracts (filled by `npm run deploy`) ----------
REVENUE_EMITTER_CONTRACT_HASH=
AGENT_VAULT_CONTRACT_HASH=

# ---------- CSPR.cloud MCP (required) ----------
# Get an API key at https://cspr.cloud
CSPR_CLOUD_API_KEY=replace_me
CSPR_CLOUD_MCP_URL=https://mcp.testnet.cspr.cloud/mcp

# ---------- CSPR.trade MCP ----------
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp

# ---------- x402 ----------
# Official CSPR.cloud x402 Facilitator (recommended).
# Docs: https://docs.cspr.cloud/x402-facilitator-api/
# Same host serves mainnet + testnet; network chosen by the CAIP-2 id in
# the PaymentPayload. Endpoints: GET /supported, POST /verify, POST /settle.
# Auth: same CSPR.cloud API key.
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
# The paid endpoint the Analyst will fetch utilization signals from.
# By default we run our own mini x402 server (npm run x402-server).
X402_SIGNAL_ENDPOINT=http://localhost:4001/signal
# CEP-18 token used for the micropayment (the asset the agent pays with).
X402_CEP18_PACKAGE_HASH=
X402_CEP18_ASSET_NAME=USDC

# ---------- x402 server (signal provider) ----------
PORT=4001
SIGNAL_PRICE_MOTES=1000000            # 0.001 CSPR
X402_PAYEE_ADDRESS=                    # hex 01... ; defaults to AGENT_PUBLIC_KEY
CASPER_NETWORK_SIGNER=casper-test

# ---------- Backend (frontend ↔ agent bridge) ----------
PORT=4000

# ---------- Frontend (CSPR.click) ----------
# Not strictly required for the basic wallet flow; the public wallet provider is used.
VITE_CSPR_CLICK_API_KEY=

# ---------- LLM strategy reasoning (optional) ----------
# If unset, the deterministic heuristic in `decideStrategy` is used.
# LLM_PROVIDER=anthropic     # or "openai"
# LLM_API_KEY=sk-...
# LLM_MODEL=claude-haiku-4-5 # or gpt-4o-mini for OpenAI
