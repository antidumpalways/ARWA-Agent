{
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["src", "tests"],
    "testMatch": ["**/*.test.ts"],
    "testTimeout": 15000,
    "moduleNameMapper": {
      "^(\\.\\.?/)+src/(.*)$": "<rootDir>/src/$2"
    },
    "globals": {
      "ts-jest": { "isolatedModules": true }
    },
    "setupFiles": ["<rootDir>/tests/setup.ts"]
  }
}
