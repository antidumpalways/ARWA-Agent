{
  "name": "parkflow-agent",
  "version": "0.3.1",
  "description": "Autonomous RWA yield agent for Casper — Analyst + Executor with real MCP, x402, CSPR.cloud REST/Streaming, and on-chain AgentVault integration.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "cycle": "tsx src/index.ts",
    "analyst": "tsx src/analyst.ts",
    "executor": "tsx src/executor.ts",
    "deploy": "tsx scripts/deploy.ts",
    "record": "tsx scripts/record-deployment.ts",
    "x402-server": "tsx scripts/x402Server.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "verify": "tsx scripts/verify-setup.ts",
    "quickstart": "tsx scripts/quickstart.ts"
  },
  "dependencies": {
    "@casper-ecosystem/casper-eip-712": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.2",
    "casper-js-sdk": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eventsource": "^2.0.2",
    "express": "^4.19.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "nock": "^13.5.6",
    "ts-jest": "^29.4.11",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
